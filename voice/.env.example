# ============================================================
# Lima voice line — environment (copy to .env)
# With nothing set, the whole call flow runs in simulation mode
# (canned transcription + canned answers + <Say> playback).
# ============================================================

VOICE_PORT=8791

# Public HTTPS base URL of THIS service (Africa's Talking must reach it).
# For local testing:  ngrok http 8791  → paste the https URL here.
#PUBLIC_BASE_URL=https://your-tunnel.ngrok.app

# --- AI (same advisor as the app) ---------------------------
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-opus-4-8

# --- Speech-to-text (pick one; see PROGRESS.md research) ----
# Vulavula (Lelapa AI) — best isiZulu/Sesotho/Afrikaans coverage
#VULAVULA_API_KEY=
# Google Cloud STT — af-ZA/zu-ZA good, st-ZA limited
#GOOGLE_STT_API_KEY=

# --- Text-to-speech -----------------------------------------
# Azure Speech — neural voices for af-ZA and zu-ZA (no Sesotho)
#AZURE_SPEECH_KEY=
#AZURE_SPEECH_REGION=southafricanorth

# --- Africa's Talking Voice ---------------------------------
# Configure your voice number's callback in the AT dashboard to:
#   POST {PUBLIC_BASE_URL}/voice/incoming
# (No key needed here — AT calls YOU. Keys above do the talking.)
