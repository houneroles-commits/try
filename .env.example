# ============================================================
# Lima — FRONTEND environment (copy to .env)
# The app runs beautifully with NOTHING set: demo mode everywhere.
# ============================================================

# Option A (recommended): run the Lima server and point the app at it.
# The Anthropic key then stays server-side (see server/.env.example).
#VITE_API_BASE=http://localhost:8790

# Option B (personal/dev only): call Anthropic directly from the browser.
# WARNING: this ships your key to every visitor — never use on a public site.
#VITE_ANTHROPIC_API_KEY=sk-ant-...

# Claude model for the assistant (default claude-opus-4-8).
# Cheaper/faster alternative: claude-haiku-4-5
#VITE_ANTHROPIC_MODEL=claude-opus-4-8
