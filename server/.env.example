# ============================================================
# Lima server — environment (copy to .env)
# Every key is OPTIONAL: missing keys switch that feature to a
# clearly-logged demo/simulation mode. Nothing breaks.
# ============================================================

PORT=8790

# --- AI assistant (Claude) ----------------------------------
# Get a key at https://platform.claude.com
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-opus-4-8

# --- SMS via Africa's Talking -------------------------------
# https://africastalking.com — use username "sandbox" while testing
#AT_USERNAME=sandbox
#AT_API_KEY=atsk_...
#AT_SENDER_ID=LIMA

# --- Web push (rain alerts as notifications) ----------------
# Generate a pair once with:  npx web-push generate-vapid-keys
#VAPID_PUBLIC_KEY=
#VAPID_PRIVATE_KEY=
#VAPID_SUBJECT=mailto:you@example.com

# --- Alert tuning -------------------------------------------
# Send "don't irrigate" alert when >= this many mm expected in 48h
#ALERT_RAIN_MM=10
# How often to check every subscriber's forecast (hours)
#ALERT_CHECK_HOURS=6
