# ============================================================
# Lima server — environment (copy this file to .env and fill in)
#   cp .env.example .env
# Every key is OPTIONAL: a missing key switches that feature to a
# clearly-logged demo/simulation mode. Nothing breaks without keys.
# ============================================================

PORT=8790

# --- AI assistant (Groq — free, fast, no billing) -----------
# Powers the WhatsApp chatbot, the in-app assistant, and photo diagnosis.
# Get a free key at https://console.groq.com/keys  (starts with gsk_)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional vision model for plant-photo diagnosis:
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- WhatsApp (Twilio) --------------------------------------
# Two-way AI chat over WhatsApp + the welcome message.
# Console: https://console.twilio.com  (Account SID + Auth Token)
# Sandbox test: Messaging -> Try it out -> Send a WhatsApp message.
#   1) From your phone, WhatsApp "join <code>" to +1 415 523 8886
#   2) Set the sandbox "When a message comes in" webhook (HTTP POST) to:
#        <PUBLIC_URL>/api/whatsapp/incoming
#      (use ngrok locally, e.g. https://xxxx.ngrok-free.app/api/whatsapp/incoming)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Default is Twilio's shared WhatsApp sandbox number. For production use your
# approved WhatsApp Business sender, e.g. whatsapp:+1xxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional: a human extension officer to notify when a farmer asks for help.
# e.g. +254700000000 (must have joined the WhatsApp sandbox too, while testing)
OFFICER_WHATSAPP=

# --- Database (optional) ------------------------------------
# Leave empty to use local JSON files (data resets on redeploy).
# For persistent memory, use a free Neon Postgres (https://neon.tech) and paste
# its connection string here, e.g. postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# --- SMS via Africa's Talking (rain alerts; optional) -------
# https://africastalking.com — username "sandbox" while testing.
AT_USERNAME=sandbox
AT_API_KEY=
#AT_SENDER_ID=LIMA

# --- Web push (rain alerts as notifications; optional) -------
# Generate a pair once with:  npx web-push generate-vapid-keys
#VAPID_PUBLIC_KEY=
#VAPID_PRIVATE_KEY=
#VAPID_SUBJECT=mailto:you@example.com

# --- Alert tuning (optional) --------------------------------
#ALERT_RAIN_MM=10
#ALERT_CHECK_HOURS=6
